{
  "name": "@adaept/ae-icon5",
  "version": "1.4.0",
  "private": false,
  "description": "adaept Icon5 Component",
  "homepage": "https://aeicon5.web.app",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "unpkg": "dist/aeicon5/aeicon5.esm.js",
  "types": "dist/types/index.d.ts",
  "customElements": "dist/components/index.js",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "files": [
    "dist/",
    "!dist/aeicon5/svg",
    "!dist/aeicon5/svg/**",
    "!dist/collection/assets",
    "!dist/collection/assets/**"
  ],
  "scripts": {
    "gen.stamp": "node scripts/gen-build-stamp.mjs",
    "prebuild": "node scripts/gen-build-stamp.mjs",
    "build": "stencil build",
    "now-build": "stencil build",
    "prestart": "node scripts/gen-build-stamp.mjs",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "check.icons": "node scripts/check-icon-manifest.mjs",
    "test.unit": "vitest run",
    "smoke": "node testing/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ionicons": "^8.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stencil/core": "^4.43.5",
    "@types/jest": "^29.5.14",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jsdom": "^26.1.0",
    "puppeteer": "^24.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adaept/ae-icon5-component.git"
  },
  "author": "adaept",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/adaept/ae-icon5-component"
  }
}